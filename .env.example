# xAI Grok API Configuration — get your key at https://x.ai/api
# Per-project key convention: this .env holds THIS project's own XAI_API_KEY.
# The xbridge-launch.sh wrapper reads it; the key is also used by Hermes' grok MCP.
# Never commit the real .env — only this .example.
XAI_API_KEY=

# Optional: force USA routing (e.g. us-east-1)
XAI_REGION=
