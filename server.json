{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.hrco/xbridge-mcp",
  "title": "xBridge MCP",
  "description": "Grok inside Claude Code — chat, web search, X search, image gen/edit, video gen, sessions, chains. 20+ tools. BYOK.",
  "version": "3.0.0",
  "websiteUrl": "https://xbridgemcp.com",
  "repository": {
    "url": "https://github.com/hrco/xbridge-mcp",
    "source": "github"
  },
  "capabilities": ["tools", "resources"],
  "tags": ["grok", "xai", "search", "twitter", "image-generation", "video-generation", "chat"],
  "packages": [
    {
      "registryType": "oci",
      "identifier": "docker.io/hrco/xbridge-mcp:latest",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": {
        "XAI_API_KEY": {
          "description": "Your xAI API key from x.ai/api",
          "required": true
        },
        "XAI_REGION": {
          "description": "Regional endpoint (e.g., us-east-1). Forces USA routing.",
          "required": false
        }
      }
    },
    {
      "registryType": "pypi",
      "identifier": "xbridge-mcp",
      "version": "3.0.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": {
        "XAI_API_KEY": {
          "description": "Your xAI API key from x.ai/api",
          "required": true
        },
        "XAI_REGION": {
          "description": "Regional endpoint (e.g., us-east-1). Forces USA routing.",
          "required": false
        }
      }
    }
  ]
}
